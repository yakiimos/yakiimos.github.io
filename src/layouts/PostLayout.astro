---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-5 sm:px-8 py-12 sm:py-16">
    <!-- 文章头部 -->
    <header class="mb-10">
      <div class="mb-5">
        <a href="/blog" class="text-sm text-brand hover:text-brand-light inline-flex items-center gap-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          返回博客
        </a>
      </div>

      <h1 class="text-2xl sm:text-3xl font-medium text-brand leading-tight mb-4 tracking-tight">
        {title}
      </h1>

      {description && (
        <p class="text-base text-olive mb-5 leading-relaxed">{description}</p>
      )}

      <div class="flex items-center gap-4 text-sm text-stone border-t border-border-soft pt-4">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {tags && tags.length > 0 && (
          <div class="flex items-center gap-2">
            {tags.map((tag: string) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="bg-brand-tint text-brand px-2 py-0.5 text-xs font-medium hover:bg-brand/10 transition-colors">
                #{tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- 文章正文 -->
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
