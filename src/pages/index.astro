---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取最新5篇博客
const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 5);
---

<BaseLayout title="首页 - My Blog">
  <!-- Hero 区域 -->
  <section class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-6xl mb-6">🚀</div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">
        你好，欢迎来到我的博客
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
        记录技术探索、学习笔记与生活感悟，偶尔分享一些有趣的网站。
      </p>
      <div class="flex items-center justify-center gap-4">
        <a
          href="/blog"
          class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors"
        >
          浏览博客
        </a>
        <a
          href="/nav"
          class="bg-white text-indigo-600 border border-indigo-200 px-6 py-3 rounded-lg font-medium hover:bg-indigo-50 transition-colors"
        >
          网址导航 →
        </a>
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">最新文章</h2>
      <a href="/blog" class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">
        查看全部 →
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {recentPosts.map((post) => (
        <article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md hover:border-indigo-200 transition-all group">
          <div class="flex flex-wrap gap-1.5 mb-3">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded font-medium">
                #{tag}
              </span>
            ))}
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors line-clamp-2">
            <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          </h3>
          {post.data.description && (
            <p class="text-sm text-gray-500 mb-4 line-clamp-2">{post.data.description}</p>
          )}
          <time class="text-xs text-gray-400">
            {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </article>
      ))}
    </div>
  </section>

  <!-- 快捷入口 -->
  <section class="bg-gradient-to-r from-indigo-600 to-purple-600 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-2xl font-bold mb-4">🧭 网址导航</h2>
      <p class="text-indigo-100 mb-6">精心收录 130+ 优质网站，涵盖 AI 工具、设计素材、学习资源等多个分类</p>
      <a
        href="/nav"
        class="bg-white text-indigo-600 px-8 py-3 rounded-lg font-semibold hover:bg-indigo-50 transition-colors inline-block"
      >
        立即探索
      </a>
    </div>
  </section>
</BaseLayout>
