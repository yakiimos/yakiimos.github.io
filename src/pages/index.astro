---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 6);
---

<BaseLayout title="首页 - 墨 Blog">
  <!-- Hero -->
  <section class="py-20 sm:py-28">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl font-medium text-brand leading-tight mb-4 tracking-tight">
        你好，欢迎来到我的博客
      </h1>
      <p class="text-lg text-olive max-w-xl mx-auto mb-8 leading-relaxed">
        记录技术探索、学习笔记与生活感悟，偶尔分享一些有趣的网站。
      </p>
      <div class="flex items-center justify-center gap-3">
        <a
          href="/blog"
          class="bg-brand text-ivory px-6 py-2.5 text-sm font-medium hover:bg-brand-light transition-colors"
        >
          浏览博客
        </a>
        <a
          href="/nav"
          class="bg-warm-sand text-dark-warm px-6 py-2.5 text-sm font-medium hover:bg-border transition-colors"
        >
          网址导航
        </a>
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-12">
    <div class="flex items-center justify-between mb-8 border-b-2 border-brand pb-3">
      <h2 class="text-xl font-medium text-brand">最新文章</h2>
      <a href="/blog" class="text-sm text-brand hover:text-brand-light font-medium">
        查看全部 &rarr;
      </a>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {recentPosts.map((post) => (
        <article class="bg-ivory border border-border p-6 hover:shadow-md hover:border-brand/20 transition-all group">
          <div class="flex flex-wrap gap-1.5 mb-3">
            {post.data.tags.map((tag: string) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs bg-brand-tint text-brand px-2 py-0.5 font-medium hover:bg-brand/10 transition-colors">
                #{tag}
              </a>
            ))}
          </div>
          <h3 class="font-medium text-near-black mb-2 group-hover:text-brand transition-colors leading-snug">
            <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          </h3>
          {post.data.description && (
            <p class="text-sm text-olive mb-4 line-clamp-2 leading-relaxed">{post.data.description}</p>
          )}
          <time class="text-xs text-stone">
            {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </article>
      ))}
    </div>
  </section>

  <!-- 网址导航入口 -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-12">
    <div class="bg-brand text-ivory py-14 px-8 text-center">
      <h2 class="text-xl font-medium mb-3">网址导航</h2>
      <p class="text-sm opacity-80 mb-6 max-w-md mx-auto leading-relaxed">
        精心收录 130+ 优质网站，涵盖 AI 工具、设计素材、学习资源等多个分类
      </p>
      <a
        href="/nav"
        class="bg-ivory text-brand px-8 py-2.5 text-sm font-medium hover:bg-warm-sand transition-colors inline-block"
      >
        立即探索
      </a>
    </div>
  </section>
</BaseLayout>
