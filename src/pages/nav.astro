---
import BaseLayout from '../layouts/BaseLayout.astro';
import sitesData from '../data/sites.json';

// 类型定义
interface Site {
  id: number;
  title: string;
  url: string;
  category: string;
  description: string;
}

const sites = sitesData as Site[];

// 按分类分组
const categoryMap = new Map<string, Site[]>();
for (const site of sites) {
  if (!categoryMap.has(site.category)) {
    categoryMap.set(site.category, []);
  }
  categoryMap.get(site.category)!.push(site);
}

// 将 Map 转为有序数组（按网站数量降序）
const categories = [...categoryMap.entries()]
  .sort((a, b) => b[1].length - a[1].length)
  .map(([name, sites]) => ({ name, sites }));

// 分类图标映射
const categoryIcons: Record<string, string> = {
  'AI工具': '🤖',
  '设计素材': '🎨',
  '在线工具': '🔧',
  '学习资源': '📚',
  '编程学习': '💻',
  '图片工具': '🖼️',
  '视频素材': '🎬',
  '音乐': '🎵',
  '娱乐': '🎮',
  '导航站': '🧭',
  '设计': '✏️',
  '笔记工具': '📝',
  '文件传输': '📤',
  '资源聚合': '📦',
  'CSS设计': '💅',
  '编程工具': '⚙️',
  '海外代购': '🛒',
};

function getCategoryIcon(category: string): string {
  return categoryIcons[category] ?? '🌐';
}

// 从 URL 获取 favicon
function getFaviconUrl(url: string): string {
  try {
    const domain = new URL(url).hostname;
    return `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
  } catch {
    return '';
  }
}

const totalSites = sites.length;
const totalCategories = categories.length;
---

<BaseLayout title="网址导航 - My Blog" description="精心收录的优质网站导航，涵盖 AI 工具、设计素材、学习资源等多个分类">
  <!-- 页面头部 -->
  <div class="bg-gradient-to-br from-indigo-600 to-purple-700 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">🧭 网址导航</h1>
      <p class="text-indigo-100 text-lg mb-6">
        精心收录 <strong class="text-white">{totalSites}</strong> 个优质网站，共 <strong class="text-white">{totalCategories}</strong> 个分类
      </p>

      <!-- 搜索框 -->
      <div class="relative max-w-xl">
        <input
          type="text"
          id="search-input"
          placeholder="搜索网站名称或描述..."
          class="w-full bg-white/10 backdrop-blur border border-white/30 text-white placeholder-indigo-200 rounded-xl px-5 py-3 pr-12 focus:outline-none focus:ring-2 focus:ring-white/50 focus:border-white/50 transition-all"
        />
        <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-indigo-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 分类快速跳转 -->
    <div class="flex flex-wrap gap-2 mb-10" id="category-nav">
      {categories.map(({ name, sites }) => (
        <a
          href={`#category-${name}`}
          class="inline-flex items-center gap-1.5 bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-600 transition-all category-tag"
          data-category={name}
        >
          <span>{getCategoryIcon(name)}</span>
          <span>{name}</span>
          <span class="bg-gray-100 text-gray-500 text-xs px-1.5 py-0.5 rounded-full">{sites.length}</span>
        </a>
      ))}
    </div>

    <!-- 搜索结果提示 -->
    <div id="search-status" class="hidden mb-6 text-sm text-gray-500">
      找到 <span id="search-count" class="font-semibold text-indigo-600">0</span> 个结果
    </div>

    <!-- 网站分类列表 -->
    <div id="sites-container" class="space-y-12">
      {categories.map(({ name, sites }) => (
        <section id={`category-${name}`} class="category-section" data-category={name}>
          <!-- 分类标题 -->
          <div class="flex items-center gap-3 mb-5">
            <span class="text-2xl">{getCategoryIcon(name)}</span>
            <h2 class="text-xl font-bold text-gray-900">{name}</h2>
            <span class="text-sm text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{sites.length} 个</span>
          </div>

          <!-- 网站卡片网格 -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 site-grid">
            {sites.map((site) => (
              <a
                href={site.url}
                target="_blank"
                rel="noopener noreferrer"
                class="site-card group flex items-start gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md hover:border-indigo-200 hover:bg-indigo-50/30 transition-all"
                data-title={site.title.toLowerCase()}
                data-description={site.description.toLowerCase()}
                data-category={site.category}
              >
                <!-- Favicon -->
                <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center overflow-hidden">
                  <img
                    src={getFaviconUrl(site.url)}
                    alt={site.title}
                    width="20"
                    height="20"
                    class="w-5 h-5 object-contain"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                    loading="lazy"
                  />
                  <span class="hidden items-center justify-center text-sm font-bold text-indigo-500">
                    {site.title.charAt(0)}
                  </span>
                </div>

                <!-- 内容 -->
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-gray-900 text-sm truncate group-hover:text-indigo-600 transition-colors">
                    {site.title}
                  </h3>
                  <p class="text-xs text-gray-500 mt-0.5 line-clamp-2 leading-relaxed">
                    {site.description}
                  </p>
                </div>

                <!-- 外链图标 -->
                <svg class="flex-shrink-0 w-4 h-4 text-gray-300 group-hover:text-indigo-400 transition-colors mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- 无结果提示 -->
    <div id="no-results" class="hidden py-20 text-center text-gray-400">
      <div class="text-5xl mb-4">🔍</div>
      <p class="text-lg">没有找到相关网站</p>
      <p class="text-sm mt-1">试试其他关键词</p>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchStatus = document.getElementById('search-status')!;
  const searchCount = document.getElementById('search-count')!;
  const noResults = document.getElementById('no-results')!;
  const sitesContainer = document.getElementById('sites-container')!;
  const categorySections = document.querySelectorAll<HTMLElement>('.category-section');
  const siteCards = document.querySelectorAll<HTMLAnchorElement>('.site-card');

  function performSearch(query: string) {
    const q = query.trim().toLowerCase();

    if (!q) {
      // 清空搜索，恢复全部显示
      categorySections.forEach((section) => (section.style.display = ''));
      siteCards.forEach((card) => (card.style.display = ''));
      searchStatus.classList.add('hidden');
      noResults.classList.add('hidden');
      sitesContainer.classList.remove('hidden');
      return;
    }

    let visibleCount = 0;

    // 过滤每个卡片
    siteCards.forEach((card) => {
      const title = card.dataset.title ?? '';
      const desc = card.dataset.description ?? '';
      const cat = (card.dataset.category ?? '').toLowerCase();
      if (title.includes(q) || desc.includes(q) || cat.includes(q)) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // 隐藏没有可见卡片的分类
    categorySections.forEach((section) => {
      const visibleCards = section.querySelectorAll<HTMLAnchorElement>('.site-card:not([style*="display: none"])');
      section.style.display = visibleCards.length > 0 ? '' : 'none';
    });

    // 更新计数
    searchCount.textContent = String(visibleCount);
    searchStatus.classList.remove('hidden');

    if (visibleCount === 0) {
      noResults.classList.remove('hidden');
      sitesContainer.classList.add('hidden');
    } else {
      noResults.classList.add('hidden');
      sitesContainer.classList.remove('hidden');
    }
  }

  searchInput.addEventListener('input', (e) => {
    performSearch((e.target as HTMLInputElement).value);
  });

  // 支持回车清空搜索
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchInput.value = '';
      performSearch('');
      searchInput.blur();
    }
  });
</script>
