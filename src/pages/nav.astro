---
import BaseLayout from '../layouts/BaseLayout.astro';
import sitesData from '../data/sites.json';

interface Site {
  id: number;
  title: string;
  url: string;
  category: string;
  description: string;
}

const sites = sitesData as Site[];

const categoryMap = new Map<string, Site[]>();
for (const site of sites) {
  if (!categoryMap.has(site.category)) {
    categoryMap.set(site.category, []);
  }
  categoryMap.get(site.category)!.push(site);
}

const categories = [...categoryMap.entries()]
  .sort((a, b) => b[1].length - a[1].length)
  .map(([name, sites]) => ({ name, sites }));

const categoryIcons: Record<string, string> = {
  'AI工具': '🤖',
  '设计素材': '🎨',
  '在线工具': '🔧',
  '学习资源': '📚',
  '编程学习': '💻',
  '图片工具': '🖼️',
  '视频素材': '🎬',
  '音乐': '🎵',
  '娱乐': '🎮',
  '导航站': '🧭',
  '设计': '✏️',
  '笔记工具': '📝',
  '文件传输': '📤',
  '资源聚合': '📦',
  'CSS设计': '💅',
  '编程工具': '⚙️',
  '海外代购': '🛒',
};

function getCategoryIcon(category: string): string {
  return categoryIcons[category] ?? '🌐';
}

function getFaviconUrl(url: string): string {
  try {
    const domain = new URL(url).hostname;
    return `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
  } catch {
    return '';
  }
}

const totalSites = sites.length;
const totalCategories = categories.length;
---

<BaseLayout title="网址导航 - 墨 Blog" description="精心收录的优质网站导航">
  <!-- 页面头部 -->
  <div class="bg-brand text-ivory py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <h1 class="text-2xl sm:text-3xl font-medium mb-2">网址导航</h1>
      <p class="text-sm opacity-75 mb-6">
        收录 <strong class="opacity-100">{totalSites}</strong> 个优质网站，共 <strong class="opacity-100">{totalCategories}</strong> 个分类
      </p>

      <div class="relative max-w-lg">
        <input
          type="text"
          id="search-input"
          placeholder="搜索网站名称或描述..."
          class="w-full bg-ivory/10 backdrop-blur border border-ivory/20 text-ivory placeholder-ivory/50 px-4 py-2.5 pr-10 text-sm focus:outline-none focus:border-ivory/40 transition-all"
        />
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ivory/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-8">
    <!-- 分类跳转 -->
    <div class="flex flex-wrap gap-2 mb-8" id="category-nav">
      {categories.map(({ name, sites }) => (
        <a
          href={`#category-${name}`}
          class="inline-flex items-center gap-1.5 bg-ivory border border-border text-dark-warm px-3 py-1.5 text-sm font-medium hover:bg-brand-tint hover:border-brand/20 hover:text-brand transition-all category-tag"
          data-category={name}
        >
          <span>{getCategoryIcon(name)}</span>
          <span>{name}</span>
          <span class="bg-warm-sand text-stone text-xs px-1.5 py-0.5">{sites.length}</span>
        </a>
      ))}
    </div>

    <!-- 搜索结果 -->
    <div id="search-status" class="hidden mb-6 text-sm text-olive">
      找到 <span id="search-count" class="font-medium text-brand">0</span> 个结果
    </div>

    <!-- 网站列表 -->
    <div id="sites-container" class="space-y-10">
      {categories.map(({ name, sites }) => (
        <section id={`category-${name}`} class="category-section" data-category={name}>
          <div class="flex items-center gap-3 mb-4 border-b border-border-soft pb-2">
            <span class="text-xl">{getCategoryIcon(name)}</span>
            <h2 class="text-lg font-medium text-brand">{name}</h2>
            <span class="text-xs text-stone bg-warm-sand px-2 py-0.5">{sites.length}</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 site-grid">
            {sites.map((site) => (
              <a
                href={site.url}
                target="_blank"
                rel="noopener noreferrer"
                class="site-card group flex items-start gap-2.5 bg-ivory border border-border p-3.5 hover:shadow-md hover:border-brand/20 transition-all"
                data-title={site.title.toLowerCase()}
                data-description={site.description.toLowerCase()}
                data-category={site.category}
              >
                <div class="flex-shrink-0 w-8 h-8 bg-warm-sand flex items-center justify-center overflow-hidden">
                  <img
                    src={getFaviconUrl(site.url)}
                    alt={site.title}
                    width="18"
                    height="18"
                    class="w-4.5 h-4.5 object-contain"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                    loading="lazy"
                  />
                  <span class="hidden items-center justify-center text-xs font-medium text-brand">
                    {site.title.charAt(0)}
                  </span>
                </div>

                <div class="flex-1 min-w-0">
                  <h3 class="font-medium text-near-black text-sm truncate group-hover:text-brand transition-colors">
                    {site.title}
                  </h3>
                  <p class="text-xs text-olive mt-0.5 line-clamp-2 leading-relaxed">
                    {site.description}
                  </p>
                </div>

                <svg class="flex-shrink-0 w-3.5 h-3.5 text-stone/40 group-hover:text-brand/40 transition-colors mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div id="no-results" class="hidden py-20 text-center text-stone">
      <p class="text-lg">没有找到相关网站</p>
      <p class="text-sm mt-1">试试其他关键词</p>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchStatus = document.getElementById('search-status')!;
  const searchCount = document.getElementById('search-count')!;
  const noResults = document.getElementById('no-results')!;
  const sitesContainer = document.getElementById('sites-container')!;
  const categorySections = document.querySelectorAll<HTMLElement>('.category-section');
  const siteCards = document.querySelectorAll<HTMLAnchorElement>('.site-card');

  function performSearch(query: string) {
    const q = query.trim().toLowerCase();

    if (!q) {
      categorySections.forEach((section) => (section.style.display = ''));
      siteCards.forEach((card) => (card.style.display = ''));
      searchStatus.classList.add('hidden');
      noResults.classList.add('hidden');
      sitesContainer.classList.remove('hidden');
      return;
    }

    let visibleCount = 0;

    siteCards.forEach((card) => {
      const title = card.dataset.title ?? '';
      const desc = card.dataset.description ?? '';
      const cat = (card.dataset.category ?? '').toLowerCase();
      if (title.includes(q) || desc.includes(q) || cat.includes(q)) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    categorySections.forEach((section) => {
      const visibleCards = section.querySelectorAll<HTMLAnchorElement>('.site-card:not([style*="display: none"])');
      section.style.display = visibleCards.length > 0 ? '' : 'none';
    });

    searchCount.textContent = String(visibleCount);
    searchStatus.classList.remove('hidden');

    if (visibleCount === 0) {
      noResults.classList.remove('hidden');
      sitesContainer.classList.add('hidden');
    } else {
      noResults.classList.add('hidden');
      sitesContainer.classList.remove('hidden');
    }
  }

  searchInput.addEventListener('input', (e) => {
    performSearch((e.target as HTMLInputElement).value);
  });

  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchInput.value = '';
      performSearch('');
      searchInput.blur();
    }
  });
</script>
